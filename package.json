    "@types/jest": "^30.0.0",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.6.0",
    "@types/supertest": "7.2.0",
    "ajv": "8.18.0",
    "ajv-formats": "3.0.1",
    "eslint": "10.2.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "^5.2.1",
    "globals": "17.4.0",
    "jest": "30.3.0",
    "jest-cli": "30.3.0",
    "prettier": "^3.3.3",
    "supertest": "^7.0.0",
    "ts-jest": "^29.4.6",
    "tsx": "^4.21.0",
